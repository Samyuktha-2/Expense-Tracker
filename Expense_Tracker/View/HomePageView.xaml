<UserControl x:Class="Expense_Tracker.View.HomePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Expense_Tracker.View"
             xmlns:conv="clr-namespace:Expense_Tracker.Converter"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        <BooleanToVisibilityConverter x:Key="boolConverter" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="20">

                    <!-- User Profile -->
                    <StackPanel HorizontalAlignment="Left"
                                Margin="0 10"
                                VerticalAlignment="Top">

                        <TextBlock Text="Expense Tracker"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="36"
                                   FontFamily="Segoe UI Semibold"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Left" />

                        <TextBlock Text="Simplified"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0 5 0 0"
                                   HorizontalAlignment="Left"
                                   FontFamily="Segoe UI" />

                    </StackPanel>
                    <local:AddTransactionView Visibility="{Binding IsReportVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,
                      Converter={StaticResource InverseBoolConverter}}" />

                </StackPanel>
            </Grid>
        </StackPanel>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="167*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="10">

                <!-- Theme Button -->
                <Button Content="{Binding ThemeIcon}"
                        Width="40"
                        Height="40"
                        Margin="5"
                        FontSize="18"
                        Background="Transparent"
                        Foreground="{DynamicResource IconColor}"
                        BorderThickness="0"
                        Command="{Binding ThemeCommand}"
                        Cursor="Hand">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"
                                    Value="{DynamicResource ButtonBackgroundBrush}" />
                            <Setter Property="BorderBrush"
                                    Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource ButtonHoverBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                </Button>

                <!-- User Avatar -->
                <Button Margin="5"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding HomePageCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40"
                                Height="40"
                                CornerRadius="20"
                                Background="{DynamicResource PrimaryBrush}"
                                VerticalAlignment="Center">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6"
                                                  ShadowDepth="1"
                                                  Opacity="0.25" />
                            </Border.Effect>

                            <TextBlock Text="{Binding UserInitial}"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="Bold" />

                        </Border>

                        <TextBlock Text="{Binding UserName}"
                                   FontSize="18"
                                   Margin="5 10 5 0"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Sitka Small"
                                   FontWeight="Bold" />

                    </StackPanel>
                </Button>

            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Grid.Row="1"
                        HorizontalAlignment="Left"
                        Margin="5">

                <!-- Income Card -->
                <Border Width="160"
                        Height="80"
                        Margin="8"
                        CornerRadius="10"
                        Background="{DynamicResource IncomeCardBrush}"
                        Padding="10">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8"
                                          ShadowDepth="2"
                                          Opacity="0.2" />
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Income"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource IncomeCard}" />

                        <TextBlock Text="{Binding TotalIncome, StringFormat=₹{0}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource IncomeCardAmount}" />
                    </StackPanel>

                </Border>

                <!-- Expense Card -->
                <Border Width="160"
                        Height="80"
                        Margin="8"
                        CornerRadius="10"
                        Background="{DynamicResource ExpenseCardBrush}"
                        Padding="10">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8"
                                          ShadowDepth="2"
                                          Opacity="0.2" />
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Expense"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ExpenseCard}" />

                        <TextBlock Text="{Binding TotalExpense, StringFormat=₹{0}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ExpenseCardAmount}" />
                    </StackPanel>

                </Border>

                <!-- Balance Card -->
                <Border Width="160"
                        Height="80"
                        Margin="8"
                        CornerRadius="10"
                        Background="{DynamicResource BalanceCardBrush}"
                        Padding="10">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8"
                                          ShadowDepth="2"
                                          Opacity="0.2" />
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Balance"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BalanceCard}" />

                        <TextBlock Text="{Binding TotalBalance, StringFormat=₹{0}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BalanceCardAmount}" />
                    </StackPanel>

                </Border>

                <!--Report Page-->
                <Button Content="Report"
                        Foreground="White"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        BorderThickness="0"
                        Command="{Binding ReportCommand}"
                        Padding="5"
                        FontSize="19"
                        FontWeight="DemiBold"
                        Margin="15"
                        Width="90"
                        Height="30">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10">
                                            <ContentPresenter VerticalAlignment="Center"
                                                              HorizontalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

            <local:FilterView Visibility="{Binding IsReportVisible,
                      Converter={StaticResource InverseBoolConverter}}"
                              Grid.Row="2" />

            <Border Grid.Row="3"
                    Margin="10"
                    Background="White"
                    CornerRadius="12"
                    Padding="10"
                    Visibility="{Binding IsReportVisible,
                     Converter={StaticResource InverseBoolConverter}}">
                <local:DataGridView />
            </Border>

            <StackPanel Grid.Row="3"
                        Grid.RowSpan="2"
                        Visibility="{Binding IsReportVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,
                               Converter={StaticResource boolConverter}}">
                <local:ReportPageView DataContext="{Binding ReportVM}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
