<UserControl x:Class="Expense_Tracker.View.ReportPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Expense_Tracker.View"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:viewmodel="clr-namespace:Expense_Tracker.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Border Grid.Row="2"
            Margin="10"
            Padding="10"
            CornerRadius="8"
            Background="{DynamicResource CardBackgroundBrush}">

        <Border.Effect>
            <DropShadowEffect BlurRadius="8"
                              ShadowDepth="1"
                              Opacity="0.2" />
        </Border.Effect>
        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="250" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Reports"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="5" />

            <!-- Month Selection -->
            <StackPanel Orientation="Horizontal"
                        Grid.Row="1"
                        Margin="5">

                <TextBlock Text="Select Month:"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="5" />

                <ComboBox Width="120"
                          ItemsSource="{Binding Months}"
                          SelectedItem="{Binding SelectedMonthName}"
                          Margin="0,0,10,0" />

                <!-- Year TextBox -->
                <TextBlock Text="Select Year:"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="5" />
                <TextBox Width="80"
                         Text="{Binding SelectedYear}"
                         HorizontalContentAlignment="Center" />

                <Border Margin="20,0,0,0"
                        Padding="10"
                        Background="#E8F5E9"
                        CornerRadius="6">
                    <TextBlock Text="{Binding TotalMonthIncome,
                      StringFormat=Total Income: ₹{0}}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                </Border>

                <Border Margin="10,0,0,0"
                        Padding="10"
                        Background="#FFEBEE"
                        CornerRadius="6">
                    <TextBlock Text="{Binding TotalMonthExpense,
                      StringFormat=Total Expense: ₹{0}}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                </Border>

            </StackPanel>

            <!-- Charts -->
            <Grid Grid.Row="2"
                  Margin="5">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Expense Pie Chart -->
                <Border Background="White"
                        Margin="5"
                        CornerRadius="6">
                    <lvc:PieChart Series="{Binding ExpenseSeries, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Border>

                <!-- Income Bar Chart -->
                <Border Background="White"
                        Grid.Column="1"
                        Margin="5"
                        CornerRadius="6">
                    <lvc:CartesianChart Series="{Binding IncomeSeries, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Border>

            </Grid>

            <!-- Transactions -->
            <DataGrid Grid.Row="3"
                      Margin="5"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      RowBackground="{DynamicResource DataGridRowBrush}"
                      AlternatingRowBackground="{DynamicResource DataGridAltRowBrush}"
                      BorderThickness="0"
                      CanUserAddRows="False"
                      Foreground="{DynamicResource DataGridRowContentColor}"
                      IsReadOnly="True"
                      CanUserResizeRows="False"
                      ItemsSource="{Binding MonthlyTransactions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight"
                                Value="Bold" />
                        <Setter Property="FontSize"
                                Value="14" />
                        <Setter Property="Foreground"
                                Value="{DynamicResource PrimaryTextBrush}" />
                        <Setter Property="Background"
                                Value="{DynamicResource DataGridHeaderBrush}" />
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Setter Property="Padding"
                                Value="10" />
                    </Style>

                    <Style TargetType="DataGridRow">
                        <Setter Property="FontSize"
                                Value="13" />
                        <Setter Property="Height"
                                Value="35" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource DataGridHoverBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <Ellipse Width="12"
                                         Height="12"
                                         VerticalAlignment="Center">

                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill"
                                                    Value="Gray" />

                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding Type}"
                                                             Value="Income">
                                                    <Setter Property="Fill"
                                                            Value="{DynamicResource IncomeColor}" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Type}"
                                                             Value="Expense">
                                                    <Setter Property="Fill"
                                                            Value="{DynamicResource ExpenseColor}" />
                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>
                                    </Ellipse.Style>

                                </Ellipse>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Type"
                                        Width="*"
                                        Binding="{Binding Type}" />
                    <DataGridTextColumn Header="Category"
                                        Width="*"
                                        Binding="{Binding Category}" />

                    <DataGridTextColumn Header="Date"
                                        Width="*"
                                        Binding="{Binding Date, StringFormat=dd MM yyyy}" />

                    <DataGridTextColumn Header="Description"
                                        Width="*"
                                        Binding="{Binding Description}" />

                    <DataGridTextColumn Header="Amount"
                                        Width="*"
                                        Binding="{Binding Amount}" />

                </DataGrid.Columns>

            </DataGrid>

        </Grid>
    </Border>
</UserControl>
