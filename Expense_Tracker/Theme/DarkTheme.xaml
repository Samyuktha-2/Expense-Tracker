<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Expense_Tracker.Theme">
    <!-- App Background -->
    <SolidColorBrush x:Key="AppBackgroundBrush"
                     Color="#0B1120" />

    <!-- Cards / Panels -->
    <SolidColorBrush x:Key="CardBackgroundBrush"
                     Color="#1F2937" />

    <!-- Primary Buttons -->
    <SolidColorBrush x:Key="PrimaryBrush"
                     Color="#3B82F6" />

    <!-- Secondary Buttons -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush"
                     Color="#FF6D7787" /> 

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush"
                     Color="#FFFFFF" />
    <SolidColorBrush x:Key="SecondaryTextBrush"
                     Color="#D1D5DB" />

    <!-- DataGrid -->
    <SolidColorBrush x:Key="DataGridHeaderBrush"
                     Color="#374151" />
    <SolidColorBrush x:Key="DataGridRowBrush"
                     Color="#1F2937" /> 
    <SolidColorBrush x:Key="DataGridAltRowBrush"
                     Color="#273244" />
    <SolidColorBrush x:Key="DataGridHoverBrush"
                     Color="#334155" />
    <SolidColorBrush x:Key="DataGridRowContentColor"
                     Color="White" />

    <!-- Summary Cards -->
    <SolidColorBrush x:Key="IncomeCardBrush"
                     Color="#065F46" />
    <SolidColorBrush x:Key="ExpenseCardBrush"
                     Color="#991B1B" />
    <SolidColorBrush x:Key="BalanceCardBrush"
                     Color="#1E40AF" />

    <!-- Status Colors -->
    <SolidColorBrush x:Key="IncomeColor"
                     Color="#34D399" />
    <SolidColorBrush x:Key="ExpenseColor"
                     Color="#F87171" />
 
    <!-- Income Card -->
    <SolidColorBrush x:Key="IncomeCard"
                     Color="#FF01FFB8" />
    <SolidColorBrush x:Key="IncomeCardAmount"
                     Color="#6EE7B7" />

    <!-- Expense Card -->
    <SolidColorBrush x:Key="ExpenseCard"
                     Color="#FFFFC8C8" />
    <SolidColorBrush x:Key="ExpenseCardAmount"
                     Color="#FCA5A5" />

    <!-- Balance Card -->
    <SolidColorBrush x:Key="BalanceCard"
                     Color="#FFA1EAFF" />
    <SolidColorBrush x:Key="BalanceCardAmount"
                     Color="#93C5FD" />
    
    <!--Theme Icon Color-->
    <SolidColorBrush x:Key="IconColor"
                     Color="Gold" />
    
    <!--Error Message Color-->
    <SolidColorBrush x:Key="ErrorMsgColour"
                     Color="White" />

</ResourceDictionary>